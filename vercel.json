{
  "version": 2,
  "buildCommand": "cd karebe-react && npx vite build",
  "outputDirectory": "karebe-react/dist",
  "installCommand": "cd karebe-react && npm install",
  "framework": "vite",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/seed",
      "destination": "/api/seed.js"
    },
    {
      "source": "/api/cart",
      "destination": "/api/cart.js"
    },
    {
      "source": "/api/orders",
      "destination": "/api/orders.js"
    },
    {
      "source": "/api/delivery",
      "destination": "/api/delivery.js"
    },
    {
      "source": "/api/riders/(.*)",
      "destination": "/api/riders.js"
    },
    {
      "source": "/api/products",
      "destination": "/api/products.js"
    },
    {
      "source": "/api/admin/login",
      "destination": "/api/admin/login.js"
    },
    {
      "source": "/api/payments/daraja/stkpush",
      "destination": "/api/payments/daraja/stkpush.js"
    },
    {
      "source": "/api/payments/daraja/callback",
      "destination": "/api/payments/daraja/callback.js"
    },
    {
      "source": "/admin/admins",
      "destination": "/karebe-react/dist/index.html"
    },
    {
      "source": "/admin/products",
      "destination": "/karebe-react/dist/index.html"
    },
    {
      "source": "/admin/branches",
      "destination": "/karebe-react/dist/index.html"
    },
    {
      "source": "/admin/settings",
      "destination": "/karebe-react/dist/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/karebe-react/dist/index.html"
    },
    {
      "source": "/rider/:path*",
      "destination": "/karebe-react/dist/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/karebe-react/dist/index.html"
    }
  ]
}
