{
  "version": 2,
  "buildCommand": "cd karebe-react && npx vite build",
  "outputDirectory": "karebe-react/dist",
  "installCommand": "cd karebe-react && npm install",
  "framework": "vite",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/cart",
      "destination": "/index.html"
    },
    {
      "source": "/checkout",
      "destination": "/index.html"
    },
    {
      "source": "/admin/login",
      "destination": "/index.html"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/admin/orders",
      "destination": "/index.html"
    },
    {
      "source": "/admin/products",
      "destination": "/index.html"
    },
    {
      "source": "/admin/branches",
      "destination": "/index.html"
    },
    {
      "source": "/admin/settings",
      "destination": "/index.html"
    },
    {
      "source": "/admin/riders",
      "destination": "/index.html"
    },
    {
      "source": "/admin/admins",
      "destination": "/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/rider/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
